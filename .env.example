# Copy to .env and adjust as needed. These are SAFE DEVELOPMENT DEFAULTS only.
# Never commit real credentials. Do not use these values in any real deployment.

# --- Postgres (used by docker-compose for the db service) ---
POSTGRES_USER=trading_bot
POSTGRES_PASSWORD=trading_bot
POSTGRES_DB=trading_bot

# --- Backend ---
# Inside docker-compose the host is the "db" service; locally use localhost.
DATABASE_URL=postgresql+psycopg://trading_bot:trading_bot@db:5432/trading_bot
# Redis URL for ARQ background jobs (M6). In docker-compose the host is "redis".
REDIS_URL=redis://localhost:6379/0
TIINGO_API_KEY=
# Alpaca PAPER trading (Phase 3). Leave empty to use the FakeBroker (no network).
# Only the paper endpoint is ever used — the base URL is hardcoded in code and
# cannot be pointed at live trading. Get free paper keys at alpaca.markets.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
LOG_LEVEL=INFO
# CORS origins allowed to call the API (the Vite dev server).
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000

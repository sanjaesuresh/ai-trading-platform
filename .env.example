# Copy to .env and adjust as needed. These are SAFE DEVELOPMENT DEFAULTS only.
# Never commit real credentials. Do not use these values in any real deployment.

# --- Postgres (used by docker-compose for the db service) ---
POSTGRES_USER=trading_bot
POSTGRES_PASSWORD=trading_bot
POSTGRES_DB=trading_bot

# --- Backend ---
# Inside docker-compose the host is the "db" service; locally use localhost.
DATABASE_URL=postgresql+psycopg://trading_bot:trading_bot@db:5432/trading_bot
LOG_LEVEL=INFO
# CORS origins allowed to call the API (the Vite dev server).
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
